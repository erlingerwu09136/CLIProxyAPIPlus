# CLIProxyAPI的示例环境配置。

#
# 注意：环境变量仅在使用远程存储选项时需要。
# 对于基于本地文件的存储（默认），不需要设置环境变量。

# ------------------------------------------------------------------------------
# 管理员网页用户界面
# ------------------------------------------------------------------------------
# 管理员密码=qqqq1111

# ------------------------------------------------------------------------------
# Postgres 令牌存储（可选）
# ------------------------------------------------------------------------------
# PGSTORE_DSN=postgresql://用户名:密码@本地主机:5432/cliproxy
# PGSTORE_SCHEMA=public
# PGSTORE_LOCAL_PATH=/var/lib/cliproxy

# ------------------------------------------------------------------------------
# Git支持的配置存储（可选）
# ------------------------------------------------------------------------------
# GITSTORE_GIT_URL=https://github.com/你的组织名/cli-proxy-config.git
# GITSTORE_GIT_USERNAME=git用户
# GITSTORE_GIT_TOKEN=ghp_你的个人访问令牌


# ------------------------------------------------------------------------------
# 对象存储令牌存储（可选）
# ------------------------------------------------------------------------------
# 对象存储端点=https://s3.your-cloud.example.com
# OBJECTSTORE_BUCKET=命令行代理配置
# OBJECTSTORE_ACCESS_KEY=qqqq1111
# OBJECTSTORE_SECRET_KEY=qqqq1111
# 对象存储本地路径=/data/cliproxy/objectstore
